{
  "name": "@kiwiproject/kiwi-test-js",
  "version": "0.0.0-semantically-released",
  "description": "kiwi-test-js is a test utility library. Most of these utilities are ports from the Java Kiwi-test library",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "/dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kiwiproject/kiwi-test-js.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "format": "npx prettier --ignore-path .gitignore --write \"**/*.+(ts|js|json)\"",
    "lint": "npx eslint --fix src",
    "test": "npx jest --coverage --collectCoverageFrom=src/**/*.ts"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "<rootDir>/__tests__/__utils__",
      "<rootDir>/node_modules/"
    ],
    "coveragePathIgnorePatterns": [
      "src/index.ts"
    ]
  },
  "dependencies": {
    "@elastic/elasticsearch": "9.4.2",
    "@jest/globals": "30.4.1",
    "@kiwiproject/kiwi-js": "1.0.0",
    "@testcontainers/elasticsearch": "12.0.4",
    "@testcontainers/postgresql": "12.0.4",
    "bignumber.js": "10.0.2",
    "convert": "7.0.0",
    "jest": "30.4.2",
    "mongodb": "7.3.0",
    "pg": "8.21.0",
    "redis": "5.12.1",
    "testcontainers": "12.0.4"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "semantic-release": "25.0.5",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.4",
    "@types/pg": "8.20.0",
    "babel-jest": "30.4.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "prettier": "3.8.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.1",
    "@types/express": "5.0.6",
    "apache-arrow": "21.1.0"
  }
}
